# Media artifacts (don't bake into image)
*.mp4
*.avi
*.mov
*.mkv
*.webm
output/
out/
results.json
keyframes.json

# Docs that aren't needed at runtime
*.md
docs/

# Logs
*.log

# NOTE: .env is intentionally NOT ignored — the Track 2 judging harness injects
# no env vars ("use your own credentials inside the container"), so the keys
# must ship in the image. Use disposable keys with spend caps.
.env.example

# Python caches
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Git / IDE
.git/
.devcontainer/
.idea/
.vscode/

# UI (not part of the container pipeline)
app.py
