# --- Cloudflare Worker Proxy ---
# Point this to your deployed worker URL. When set, all API traffic goes
# through the worker (which handles auth + fallback chains). The Fireworks
# direct keys below become optional and can use the dummy value "worker-proxy".
WORKER_URL=https://your-worker.workers.dev

# --- Fireworks AI Configuration (vision, key #1) ---
# Only needed when NOT using WORKER_URL (direct mode).
# Get yours at: https://fireworks.ai/account/api-keys
# FIREWORKS_API_KEY=your_fireworks_vision_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Optional: Override default Fireworks vision model
# FIREWORKS_VISION_MODEL=accounts/fireworks/models/minimax-m3

# --- Fireworks AI Configuration (text, key #2) ---
# Only needed when NOT using WORKER_URL (direct mode).
# Falls back to FIREWORKS_API_KEY when unset.
# FIREWORKS_TEXT_API_KEY=your_fireworks_text_key_here
# FIREWORKS_TEXT_BASE_URL=https://api.fireworks.ai/inference/v1

# Optional: Override default Fireworks text model
# FIREWORKS_TEXT_MODEL=accounts/fireworks/models/gpt-oss-120b
